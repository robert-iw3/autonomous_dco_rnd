# ==============================================================================
# threshold.config -- risk-based escalation & noise filtering
#
# This file is where "what to block, and how much" is tuned WITHOUT editing
# rules. Three mechanisms:
#
#   rate_filter  -- RISK-BASED ESCALATION. Start a rule as 'alert'; once a source
#                  crosses a frequency threshold, switch its action to 'drop'
#                  for a timeout window. This is how Tier-2 (suspicious.rules)
#                  behaviour-blocks repeat offenders while leaving one-off
#                  events as alerts only. Per-source, so it's environment-neutral.
#
#   threshold    -- LIMIT/THRESHOLD alert volume per rule (anti-log-flood).
#
#   suppress     -- FILTER OUT specific alerts (by SID, host, or net) to kill
#                  known false positives without disabling the rule globally.
#
# Reload after edits:  suricatasc -c reload-rules    (or restart)
# ==============================================================================

# ------------------------------------------------------------------------------
# RISK-BASED ESCALATION (rate_filter): alert -> drop on sustained bad behaviour
# Syntax: rate_filter gen_id <g>, sig_id <sid>, track <by_src|by_dst|by_rule>,
#         count <N>, seconds <T>, new_action <drop|reject|alert>, timeout <secs>
# ------------------------------------------------------------------------------

# TCP SYN scan (sid 2100001): >100 SYNs from one source in 10s -> drop for 5 min.
rate_filter gen_id 1, sig_id 2100001, track by_src, count 100, seconds 10, new_action drop, timeout 300

# SSH brute force (sid 2100010): >10 new sessions in 60s from one src -> drop 10 min.
rate_filter gen_id 1, sig_id 2100010, track by_src, count 10, seconds 60, new_action drop, timeout 600

# HTTP login brute / cred stuffing (sid 2100020): >25 in 60s -> drop 10 min.
rate_filter gen_id 1, sig_id 2100020, track by_src, count 25, seconds 60, new_action drop, timeout 600

# DNS exfil heuristic (sid 2100030): >200 queries in 60s from one host -> drop 5 min.
rate_filter gen_id 1, sig_id 2100030, track by_src, count 200, seconds 60, new_action drop, timeout 300

# Outbound backdoor-port C2 (sid 2100040): >3 connections in 30s -> drop 15 min.
rate_filter gen_id 1, sig_id 2100040, track by_src, count 3, seconds 30, new_action drop, timeout 900

# ------------------------------------------------------------------------------
# ALERT-VOLUME LIMITING (threshold): keep the log readable on noisy sigs.
# type limit  -> at most N alerts per T seconds per tracked key.
# ------------------------------------------------------------------------------

# Large outbound flow visibility (sid 2200020): at most 1 alert/min/host.
threshold gen_id 1, sig_id 2200020, type limit, track by_src, count 1, seconds 60

# Self-signed TLS visibility (sid 2200010): 1 alert per 5 min per dest.
threshold gen_id 1, sig_id 2200010, type limit, track by_dst, count 1, seconds 300

# ------------------------------------------------------------------------------
# FALSE-POSITIVE FILTERING (suppress): silence specific alerts without disabling
# the rule for everyone. Uncomment + edit per environment.
# ------------------------------------------------------------------------------

# Example: stop the SYN-scan rule firing on an internal monitoring host.
#suppress gen_id 1, sig_id 2100001, track by_src, ip 10.0.0.50

# Example: globally suppress a single noisy managed-feed SID.
#suppress gen_id 1, sig_id 2013028

# Example: suppress a rule only for an entire trusted subnet.
#suppress gen_id 1, sig_id 2100020, track by_src, ip 10.10.0.0/24