# ==============================================================================
# block-known-bad.rules -- TIER 1 (action: drop)  [SID 2000000-2000999 reserved]
#
# High-confidence, low-false-positive. DROP under the 'balanced' policy and up.
# DATA-DRIVEN: indicators live in mounted dataset files under /etc/suricata/data,
# so the same rules work in any environment and blocklists update without rule
# edits. Populate (one entry per line; NO comments inside .lst files):
#   bad_ips.lst       raw IPs (type ip)
#   bad_domains.lst   domain strings (type string)
#   bad_sni.lst       TLS SNI strings (type string)
#   bad_ja3.lst       JA3 hash strings (type string)
#   bad_file_md5.lst  MD5 hashes (type md5)
# ==============================================================================

# --- IOC: known-bad IPs (ip.src/ip.dst sticky buffers + ip dataset) ---
drop ip any any -> $HOME_NET any (msg:"BLOCK ingress from known-bad IP (dataset)"; ip.src; dataset:isset,bad-ips; sid:2000001; rev:1;)
drop ip $HOME_NET any -> any any (msg:"BLOCK egress to known-bad IP (dataset)"; ip.dst; dataset:isset,bad-ips; sid:2000002; rev:1;)

# --- IOC: DNS query for known-bad domain (dns.query sticky buffer + string dataset) ---
drop dns $HOME_NET any -> any any (msg:"BLOCK DNS to known-bad domain (dataset)"; dns.query; dataset:isset,bad-domains; sid:2000010; rev:1;)

# --- IOC: TLS to known-bad SNI / JA3 (C2 over TLS) ---
drop tls $HOME_NET any -> any any (msg:"BLOCK TLS to known-bad SNI (dataset)"; tls.sni; dataset:isset,bad-tls-sni; sid:2000020; rev:1;)
drop tls $HOME_NET any -> any any (msg:"BLOCK TLS known-bad JA3 (dataset)"; ja3.hash; dataset:isset,bad-ja3; sid:2000021; rev:1;)

# --- IOC: known-bad file download by MD5 (file.data sticky buffer + md5 dataset) ---
drop http any any -> $HOME_NET any (msg:"BLOCK known-bad file MD5 (dataset)"; file.data; to_md5; dataset:isset,bad-file-md5; sid:2000030; rev:1;)

# --- Generic exploitation patterns (signature-based, env-agnostic) ---
drop tcp $EXTERNAL_NET any -> $DOCKER_HOSTS $DOCKER_API_PORTS (msg:"BLOCK external access to container runtime API"; flow:to_server; sid:2000100; rev:1;)
drop tcp $EXTERNAL_NET any -> $K8S_API 10250 (msg:"BLOCK external kubelet API access"; flow:to_server; sid:2000101; rev:1;)

drop http $EXTERNAL_NET any -> $HTTP_SERVERS any (msg:"BLOCK reverse shell payload (bash -i)"; flow:to_server; http.request_body; content:"bash -i >& /dev/tcp/"; nocase; sid:2000110; rev:1;)
drop http $EXTERNAL_NET any -> $HTTP_SERVERS any (msg:"BLOCK pipe-to-shell loader in URI"; flow:to_server; http.uri; pcre:"/(curl|wget)\s+[^|]+\|\s*(ba)?sh/i"; sid:2000111; rev:1;)