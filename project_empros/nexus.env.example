# ==============================================================================
# Sentinel Nexus -- Local Dev Environment Variables
# Copy to nexus.env and fill in values before running docker-compose.
#   cp nexus.env.example nexus.env
# nexus.env is gitignored. Never commit it.
# ==============================================================================

# -- Ingress Security ----------------------------------------------------------
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32
INTEGRITY_HMAC_SECRET=change_me_generate_with_openssl_rand_base64_32
INTEGRITY_BAN_THRESHOLD=5
MAX_PAYLOAD_BYTES=10485760
DLQ_PREFIX=nexus.dlq

# -- NATS Authentication -------------------------------------------------------
NATS_NKEY_SEED=

# -- S3 / MinIO Storage --------------------------------------------------------
S3_BUCKET_NAME=nexus-cold-storage
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_ENDPOINT=http://minio:9000

# -- LLM Providers (leave blank to use only local sovereign model) -------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# -- Observability -------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin

# -- SOAR / Incident Webhook ---------------------------------------------------
INCIDENT_WEBHOOK_URL=http://n8n:5678/webhook/master-containment
