# ==============================================================================
# Eval MiniLab -- copy to .env and adjust
# ==============================================================================

# Model for inference validation.
# Laptop / CPU:  llama3.2:1b  llama3.2:3b (default)  phi3:mini  gemma2:2b
# GPU (6-8GB):   llama3.1:8b-instruct-q4_0  deepseek-r1:7b
EVAL_MODEL=llama3.2:3b

# Stop on first gate failure instead of running all gates
EVAL_FAIL_FAST=0

# Verbose output (1=yes, 0=brief)
EVAL_VERBOSE=1

# CPU thread count for Ollama
OLLAMA_NUM_THREAD=4
