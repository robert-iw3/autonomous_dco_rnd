# SECTION: analytics
# Tests:   lab_analytics_hunter/, lab_agentic_swarm/, lab_redteam/
# Deps:    pytest, pydantic, PyYAML, numpy
#          (langchain_core / nats / redis / prometheus are stubbed in each test)
#   docker build -f project_empros/tests/Dockerfile.analytics -t nexus-test-analytics .
FROM docker.io/alpine:3.23

RUN apk add --no-cache python3 py3-pip

ENV PIP_BREAK_SYSTEM_PACKAGES=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

RUN pip3 install --no-cache-dir \
    "pytest>=7.4.0" \
    "numpy>=2.0.0" \
    "pydantic>=2.7.1" \
    "PyYAML>=6.0"

COPY project_empros/analytics/llm_hunter/       /repo/project_empros/analytics/llm_hunter/
COPY project_empros/tests/lab_analytics_hunter/ /repo/project_empros/tests/lab_analytics_hunter/
COPY project_empros/tests/lab_agentic_swarm/    /repo/project_empros/tests/lab_agentic_swarm/
COPY project_empros/tests/lab_redteam/          /repo/project_empros/tests/lab_redteam/
COPY project_empros/tests/simulation/           /repo/project_empros/tests/simulation/
COPY project_empros/tests/pytest.ini            /repo/project_empros/tests/

ENV PYTHONPATH=/repo/project_empros/analytics/llm_hunter:/repo/project_empros/analytics:/repo/project_empros
WORKDIR /repo/project_empros

CMD ["python3", "-m", "pytest", \
     "tests/lab_analytics_hunter/", \
     "tests/lab_agentic_swarm/", \
     "tests/lab_redteam/", \
     "-v", "--tb=short", "--junit-xml=/reports/analytics.xml"]
