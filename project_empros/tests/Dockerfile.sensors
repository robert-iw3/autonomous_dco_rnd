# SECTION: sensors
# Tests:   tests/sensors/* (all sensor pipeline schema + vector validation)
# Deps:    pytest, numpy, pyarrow, pandas, pydantic
#   docker build -f project_empros/tests/Dockerfile.sensors -t nexus-test-sensors .
FROM docker.io/alpine:3.23

RUN apk add --no-cache \
    python3 python3-dev py3-pip \
    gcc g++ musl-dev linux-headers libffi-dev openssl-dev

ENV PIP_BREAK_SYSTEM_PACKAGES=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

RUN pip3 install --no-cache-dir \
    "pytest>=7.4.0" \
    "numpy>=2.0.0" \
    "pyarrow>=16.0.0" \
    "pandas>=2.2.0" \
    "pydantic>=2.7.1"

# project_empros source
COPY project_empros/mlops/scripts/           /repo/project_empros/mlops/scripts/
COPY project_empros/mlops/config/            /repo/project_empros/mlops/config/
COPY project_empros/services/config/         /repo/project_empros/services/config/
COPY project_empros/services/worker_qdrant/  /repo/project_empros/services/worker_qdrant/
COPY project_empros/tests/config/            /repo/project_empros/tests/config/
COPY project_empros/tests/deploy/            /repo/project_empros/tests/deploy/
COPY project_empros/tests/sensors/           /repo/project_empros/tests/sensors/
COPY project_empros/tests/pytest.ini         /repo/project_empros/tests/

# Repo-root sensor sources (linux/c2_sensor, linux/sentinel, linux/suricata,
# infra/aws, infra/azure, infra/gcp, infra/network_tap, windows/).
# Tests read Cargo.toml + *.rs source files via ROOT = REPO.parent.
# Large data/ and img/ dirs are excluded via .dockerignore.
COPY infra/     /repo/infra/
COPY linux/     /repo/linux/
COPY windows/   /repo/windows/

ENV PYTHONPATH=/repo/project_empros/mlops/scripts:/repo/project_empros
WORKDIR /repo/project_empros

CMD ["python3", "-m", "pytest", "tests/sensors/", "-v", "--tb=short", "--junit-xml=/reports/sensors.xml"]
