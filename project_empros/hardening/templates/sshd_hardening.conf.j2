# ==============================================================================
# Sentinel Nexus -- SSH Server Hardening (drop-in)
# Managed by Ansible -- common_hardening role
# ==============================================================================

Port {{ hardening_ssh_port }}
Protocol 2

# Authentication
PermitRootLogin no
MaxAuthTries {{ hardening_ssh_max_auth_tries }}
MaxSessions {{ hardening_ssh_max_sessions }}
PermitEmptyPasswords no
HostbasedAuthentication no
IgnoreUserKnownHosts yes
PermitUserEnvironment no
StrictModes yes
AllowGroups {{ hardening_ssh_allowed_groups }}
LoginGraceTime {{ hardening_ssh_login_grace_time }}
MaxStartups {{ hardening_ssh_max_startups }}

# Cryptography -- strong algorithms only
KexAlgorithms {{ hardening_ssh_kex_algorithms | regex_replace('\s+', '') }}
Ciphers {{ hardening_ssh_ciphers | regex_replace('\s+', '') }}
MACs {{ hardening_ssh_macs | regex_replace('\s+', '') }}
RekeyLimit {{ hardening_ssh_rekey_limit }}

# Session
ClientAliveInterval {{ hardening_ssh_client_alive_interval }}
ClientAliveCountMax {{ hardening_ssh_client_alive_count_max }}
TCPKeepAlive no
UseDNS no

# Logging
LogLevel VERBOSE
PrintLastLog yes

# Forwarding -- disabled on headless infra nodes
X11Forwarding no
AllowTcpForwarding no
AllowAgentForwarding no

# Misc
Compression no
Banner /etc/issue.net
Subsystem sftp internal-sftp

# Kerberos/GSSAPI -- disabled for local auth
KerberosAuthentication no
GSSAPIAuthentication no